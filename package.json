{
  "name": "pack-api",
  "version": "1.0.0",
  "description": "Our API for packUP",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run barrels && swc src --out-dir dist -s",
    "barrels": "barrelsby --config .barrelsby.json",
