    "method-override": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.2",
    "@swc-node/register": "^1.10.9",
    "@swc/cli": "^0.4.1-nightly.20240914",
    "@swc/core": "^1.7.28",
    "@swc/helpers": "^0.5.13",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
