    "@tsed/engines": "^7.83.1",
    "@tsed/exceptions": "^7.83.1",
    "@tsed/json-mapper": "^7.83.1",
    "@tsed/logger": "^6.7.8",
    "@tsed/logger-file": "^6.7.8",
    "@tsed/openspec": "^7.83.1",
    "@tsed/platform-cache": "^7.83.1",
    "@tsed/platform-exceptions": "^7.83.1",
    "@tsed/platform-express": "^7.83.1",
    "@tsed/platform-log-middleware": "^7.83.1",
    "@tsed/platform-middlewares": "^7.83.1",
    "@tsed/platform-params": "^7.83.1",
    "@tsed/platform-response-filter": "^7.83.1",
    "@tsed/platform-views": "^7.83.1",
    "@tsed/schema": "^7.83.1",
    "ajv": "^8.17.1",
    "barrelsby": "^2.8.1",
    "body-parser": "^1.20.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
